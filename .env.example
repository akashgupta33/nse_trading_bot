# Fyers API Credentials
FYERS_CLIENT_ID=your_fyers_client_id_here
FYERS_SECRET_KEY=your_fyers_secret_key_here
FYERS_REDIRECT_URI=https://127.0.0.1:8080/
FYERS_ACCESS_TOKEN=your_fyers_access_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Capital Allocation
PAPER_CAPITAL=1000000
LIVE_CAPITAL=20000
RISK_PER_TRADE_PCT=1.5

# Portfolio Limits
MAX_POSITIONS=4
CASH_RESERVE_PCT=10.0

# Minimum Conviction Score
MIN_CONVICTION_SCORE=7.0

# Hold Duration Limits (days)
MAX_HOLD_DAYS=45
STALE_TRADE_DAYS=15
STALE_TRADE_MIN_GAIN_PCT=3.0

# Screener Configuration
SCREENER_TOP_N=20
SCREENER_MIN_MARKET_CAP_CR=500
SCREENER_MIN_PRICE=50.0

# NSE Watchlist (comma-separated)
NSE_WATCHLIST=NSE:RELIANCE-EQ,NSE:TCS-EQ,NSE:HDFCBANK-EQ,NSE:ICICIBANK-EQ,NSE:INFY-EQ,NSE:ITC-EQ,NSE:SBIN-EQ,NSE:BHARTIARTL-EQ,NSE:BAJFINANCE-EQ,NSE:LT-EQ,NSE:MARUTI-EQ,NSE:SUNPHARMA-EQ,NSE:WIPRO-EQ,NSE:ULTRACEMCO-EQ,NSE:HCLTECH-EQ,NSE:POWERGRID-EQ,NSE:NTPC-EQ,NSE:ONGC-EQ,NSE:COALINDIA-EQ,NSE:M&M-EQ,NSE:TATAMOTORS-EQ,NSE:TATACONSUM-EQ,NSE:BAJAJFINSV-EQ,NSE:BEL-EQ,NSE:HINDALCO-EQ,NSE:JSWSTEEL-EQ,NSE:TATASTEEL-EQ,NSE:HAVELLS-EQ,NSE:PIDILITIND-EQ,NSE:INDIGO-EQ,NSE:ZOMATO-EQ,NSE:HAL-EQ,NSE:BHEL-EQ,NSE:IRCTC-EQ,NSE:COFORGE-EQ,NSE:ASTRAL-EQ,NSE:SUPREMEIND-EQ,NSE:CONCOR-EQ,NSE:PETRONET-EQ,NSE:SAIL-EQ,NSE:VEDL-EQ,NSE:LUPIN-EQ,NSE:DEEPAKNTR-EQ,NSE:PIIND-EQ,NSE:VOLTAS-EQ,NSE:APOLLOTYRE-EQ,NSE:EXIDEIND-EQ,NSE:DLF-EQ,NSE:PRESTIGE-EQ

# Intraday Monitor
INTRADAY_CHECK_INTERVAL_MIN=30
INTRADAY_CLAUDE_TRIGGER_PCT=3.0

# Market Filters
NIFTY_SYMBOL=NSE:NIFTY50-INDEX
NIFTY_ABOVE_EMA200_REQUIRED=True

# Database Path
DB_PATH=logs/trades.db
